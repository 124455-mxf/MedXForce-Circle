# Copy values from medxforce/firebase-applet-config.json (same Firebase project as patient app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Leave empty to use Firestore (default) — required for Blaze write quotas.
# Only set this if you intentionally use a named database.
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# Optional — enables private AI guidance on Circle tab (not posted to threads)
VITE_GEMINI_API_KEY=

# Patient app server — required for visit capture (transcription + publish)
VITE_MEDXFORCE_API_URL=http://localhost:3000
